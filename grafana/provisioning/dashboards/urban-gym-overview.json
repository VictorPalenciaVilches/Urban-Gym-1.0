        { "expr": "rate(facility_service_process_cpu_user_seconds_total[1m])", "legendFormat": "Facility Service CPU", "refId": "C" },
        { "expr": "rate(iot_service_process_cpu_user_seconds_total[1m])", "legendFormat": "IoT Service CPU", "refId": "D" },
        { "expr": "rate(workout_progress_service_process_cpu_user_seconds_total[1m])", "legendFormat": "Workout Progress CPU", "refId": "E" },
        { "expr": "rate(billing_service_process_cpu_user_seconds_total[1m])", "legendFormat": "Billing Service CPU", "refId": "F" },
        { "expr": "rate(recommendation_service_process_cpu_user_seconds_total[1m])", "legendFormat": "Recommendation CPU", "refId": "G" },
        { "expr": "rate(admin_bff_process_cpu_user_seconds_total[1m])", "legendFormat": "Admin BFF CPU", "refId": "H" },
        { "expr": "rate(api_gateway_process_cpu_user_seconds_total[1m])", "legendFormat": "API Gateway CPU", "refId": "I" }
      ],
      "title": "CPU User Time Rate (1m)",
      "type": "timeseries"
