{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Métricas de los microservicios de Urban GYM recolectadas por Prometheus",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🏋️ Urban GYM — Estado de Microservicios",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" }, "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "pluginVersion": "10.0.0",
      "targets": [
        { "expr": "up{job=\"api-gateway\"}", "legendFormat": "API Gateway", "refId": "A" },
        { "expr": "up{job=\"member-service\"}", "legendFormat": "Member Service", "refId": "B" },
        { "expr": "up{job=\"booking-service\"}", "legendFormat": "Booking Service", "refId": "C" },
        { "expr": "up{job=\"facility-service\"}", "legendFormat": "Facility Service", "refId": "D" },
        { "expr": "up{job=\"iot-service\"}", "legendFormat": "IoT Service", "refId": "E" },
        { "expr": "up{job=\"workout-progress-service\"}", "legendFormat": "Workout Progress", "refId": "F" },
        { "expr": "up{job=\"billing-service\"}", "legendFormat": "Billing Service", "refId": "G" },
        { "expr": "up{job=\"recommendation-service\"}", "legendFormat": "Recommendation", "refId": "H" },
        { "expr": "up{job=\"admin-bff\"}", "legendFormat": "Admin BFF", "refId": "I" }
      ],
      "title": "Estado de Servicios (UP/DOWN)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
